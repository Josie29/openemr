# AgentForge Clinical Co-Pilot — agent service configuration.
# Copy to `.env` for local dev. All secrets come from the environment (never committed).
# On Railway these are set as service variables. Prefix is COPILOT_.

# --- Agent / LLM ---
# Model tier. Options (cheapest -> priciest):
#   anthropic:claude-haiku-4-5  (~$1/$5 per Mtok — cheapest; use for plumbing tests)
#   anthropic:claude-sonnet-5   (default workhorse; judge answer quality on this)
#   anthropic:claude-opus-4-8   (hardest reasoning; reserve for eval-driven cases)
COPILOT_MODEL_TIER=anthropic:claude-sonnet-5
# Required for live LLM calls and the /ready LLM probe. Omit to run tests (they use FunctionModel).
COPILOT_ANTHROPIC_API_KEY=

# --- Document extraction (Mistral OCR — the intake-extractor's OCR, JOS-54/JOS-80) ---
# attach_and_extract OCRs an uploaded document into cited facts. WHICH schema it is read through is
# decided by the document's own OpenEMR category (Lab Report -> lab_pdf, Patient Information ->
# intake_form), never by the model — so the fixture settings below are per document TYPE.
# mistral  = live Mistral OCR schema mode (the code default, so the deployed service runs real OCR).
# fixture  = replay a recorded OCR response; set here + in tests for fully-offline runs (no live
#            API, no cost). A type with no recording configured raises rather than replaying some
#            other type's response — a lab response mapped as an intake form yields zero facts and
#            would otherwise look like "this document is empty".
COPILOT_EXTRACTOR_MODE=fixture
# Required for live (mistral) extraction and nothing else. The Mistral SDK's native MISTRAL_API_KEY
# is also accepted. Omit when EXTRACTOR_MODE=fixture.
# NOTE: live extraction also needs the optional SDK — `pip install -e ".[extraction]"` then
# `pip install opentelemetry-semantic-conventions==0.63b1` (mistralai pins otel below langfuse's
# floor). Without it every extraction degrades to "no document facts".
COPILOT_MISTRAL_API_KEY=
# The demo byte-source, per document type: the committed PDF whose bytes are fed to OCR. In fixture
# FHIR mode these are served to whichever SEEDED document has that type, so an intake extraction
# reads the intake form's own page rather than the lab report's. Unset = that type is not extractable
# (the intake-extractor reports no uploaded document rather than failing).
# The unsuffixed COPILOT_DOCUMENT_PDF_PATH / COPILOT_OCR_FIXTURE_PATH still work as the lab_pdf ones.
COPILOT_DOCUMENT_PDF_PATH_LAB_PDF=tests/fixtures/documents/pdfs/sergio-angulo-lab-report.pdf
COPILOT_DOCUMENT_PDF_PATH_INTAKE_FORM=tests/fixtures/documents/pdfs/sergio-angulo-intake-form.pdf
# fixture mode only: the recorded Mistral OCR response replayed instead of a live call, per type.
COPILOT_OCR_FIXTURE_PATH_LAB_PDF=tests/fixtures/documents/extractions/sergio-angulo-lab-report.ocr.json
COPILOT_OCR_FIXTURE_PATH_INTAKE_FORM=tests/fixtures/documents/extractions/sergio-angulo-intake-form.ocr.json

# --- FHIR data access (SMART patient/*.read; no DB credentials) ---
# fixture = replay bundled seed patient (set here for easy local dev; no OpenEMR needed).
# http    = live OpenEMR FHIR R4 (requires base URL + a per-request SMART token). This is the
#           code default, so the deployed service is secure (a tokenless /chat is refused).
COPILOT_FHIR_CLIENT_MODE=fixture
COPILOT_FHIR_BASE_URL=
# Fallback only. oe-module-ai-copilot mints a per-request, patient-scoped token and sends it as
# `Authorization: Bearer`; /chat prefers that over this static one. A static token is identical for
# every caller and so enforces no per-patient scoping — leave it unset outside local dev.
COPILOT_FHIR_BEARER_TOKEN=
COPILOT_FHIR_TIMEOUT_SECONDS=10
COPILOT_FHIR_MAX_RETRIES=2

# --- Browser access (CORS) ---
# Comma-separated origins allowed to call POST /chat from the browser. The chat XHR goes straight
# from the physician's browser to this service (ARCHITECTURE.md §4), which is always cross-origin.
# Defaults to empty: no browser origin is permitted unless named here. Never set this to "*" —
# that would let any page on the internet spend a stolen SMART token.
#   local demo: http://localhost:8301   (the OpenEMR dev stack's HTTP origin)
COPILOT_CORS_ORIGINS=

# --- Hybrid RAG evidence retrieval (JOS-53) ---
# qdrant  = live pipeline: Qdrant hybrid (FastEmbed dense+sparse -> RRF) + Cohere rerank. This is
#           the code default, so the deployed service uses the real retriever.
# fixture = in-process keyword retriever over the in-repo corpus (no Qdrant/Cohere, no Docker) —
#           set here so local dev + the test suite run fully offline.
COPILOT_RETRIEVAL_MODE=fixture
# Live-mode (RETRIEVAL_MODE=qdrant) only. On Railway, QDRANT_URL is the private service URL —
# plain http (Wireguard already encrypts): http://qdrant.railway.internal:6333. Bare QDRANT_URL /
# QDRANT_API_KEY are accepted (as well as the COPILOT_-prefixed forms).
QDRANT_URL=
QDRANT_API_KEY=
COPILOT_QDRANT_COLLECTION=guidelines
# Cohere rerank API key. The SDK's native CO_API_KEY and plain COHERE_API_KEY are both accepted.
COHERE_API_KEY=

# --- Observability (Langfuse) ---
# Native Langfuse variable names — copy straight from Langfuse -> Settings -> API Keys.
# (The COPILOT_LANGFUSE_* forms are also accepted.) Omit both keys to run untraced.
# BASE_URL must match your project region: EU https://cloud.langfuse.com,
# US https://us.cloud.langfuse.com — a mismatch causes a 401 and disables tracing.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
# Stamped on every trace so dev/eval/prod are filterable in one Langfuse project. Keep this
# `development` locally; set LANGFUSE_TRACING_ENVIRONMENT=production as a Railway variable.
LANGFUSE_TRACING_ENVIRONMENT=development
