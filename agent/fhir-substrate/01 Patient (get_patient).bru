meta {
  name: 01 Patient (get_patient)
  type: http
  seq: 2
}

get {
  url: {{base_url}}/Patient/{{patient_id}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

headers {
  Accept: application/fhir+json
}

docs {
  Wraps the agent tool `get_patient`. A direct read of the Patient resource by logical id
  (not a search) — the single request that returns one resource rather than a searchset
  Bundle. The tool parses this into `PatientDemographics` (src/copilot/fhir/models.py).
}

assert {
  res.status: eq 200
  res.body.resourceType: eq Patient
}
