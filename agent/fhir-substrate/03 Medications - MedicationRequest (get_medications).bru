meta {
  name: 03 Medications - MedicationRequest (get_medications)
  type: http
  seq: 4
}

get {
  url: {{base_url}}/MedicationRequest?patient={{patient_id}}
  body: none
  auth: bearer
}

params:query {
  patient: {{patient_id}}
}

auth:bearer {
  token: {{access_token}}
}

headers {
  Accept: application/fhir+json
}

docs {
  Wraps the agent tool `get_medications`. Searches MedicationRequest for the patient. Note
  the tool post-processes the raw Bundle with `dedup_medications` — the same drug can appear
  as multiple requests, so the tool's output is *fewer* rows than this raw searchset.
}

assert {
  res.status: eq 200
  res.body.resourceType: eq Bundle
}
