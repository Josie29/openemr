meta {
  name: 04 Auth - Refresh Token
  type: http
  seq: 4
}

post {
  url: {{oauth_url}}
  body: formUrlEncoded
  auth: none
}

body:form-urlencoded {
  grant_type: refresh_token
  refresh_token: {{refresh_token}}
  client_id: {{client_id}}
  client_secret: {{client_secret}}
}

docs {
  Exchanges the long-lived (3-month) refresh token for a fresh 1-hour access token,
  scoped to a single patient (patient/*.read). Run this first each session; the
  post-response script stashes the new access_token for the /chat requests below.

  OpenEMR rotates the refresh token on each use, so the script also writes the new
  refresh_token back into the environment to keep the chain alive. If this returns
  400 invalid_grant, the refresh token has expired or been rotated out of sync —
  re-mint one (see the collection README) and paste it into refresh_token.
}

script:post-response {
  if (res.getStatus() === 200) {
    const body = res.getBody();
    if (body.access_token) {
      bru.setEnvVar("access_token", body.access_token);
    }
    // Refresh tokens rotate on use; persist the new one or the next refresh 400s.
    if (body.refresh_token) {
      bru.setEnvVar("refresh_token", body.refresh_token);
    }
  }
}

assert {
  res.status: eq 200
  res.body.access_token: isDefined
}
